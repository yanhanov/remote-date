# Скопируйте в front/.env

# Порт API для Vite proxy (должен совпадать с PORT бэкенда; по умолчанию 5001)
VITE_API_PORT=5001

# Явные URL (опционально — обходят proxy; на бэкенде нужен CORS)
# VITE_API_URL=http://localhost:5001/api
# VITE_SOCKET_URL=ws://localhost:5001/ws

# Docker (бэкенд на 5000)
# VITE_API_PORT=5000
# VITE_API_URL=http://localhost:5000/api
# VITE_SOCKET_URL=ws://localhost:5000/ws
