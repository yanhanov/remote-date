# Скопируйте в back-rs/.env (подхватывается через dotenvy при cargo run)

# HTTP-порт (по умолчанию 5000; make dev использует 5001 через Makefile)
PORT=5001

# MongoDB
MONGO_URL=mongodb://localhost:27017/remote

# JWT (в production задайте свой секрет)
JWT_SECRET=super-secret-dev
JWT_EXPIRES_IN=7d

# YouTube Data API v3 — https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=

# SoundCloud — https://developers.soundcloud.com/docs/api/guide#authentication
SOUNDCLOUD_CLIENT_ID=

# Опционально: уровень логов (RUST_LOG=back_rs=debug,axum=info)
# RUST_LOG=back_rs=debug,axum=info,tower_http=info
