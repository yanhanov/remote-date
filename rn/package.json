{
  "name": "rn",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-cookies/cookies": "^6.2.1",
    "@react-navigation/bottom-tabs": "^7.18.8",
    "@react-navigation/native": "^7.3.8",
    "@react-navigation/native-stack": "^7.17.10",
    "expo": "~57.0.4",
    "expo-build-properties": "~57.0.3",
    "expo-crypto": "^57.0.0",
    "expo-document-picker": "^57.0.0",
    "expo-image-picker": "^57.0.2",
    "expo-linking": "^57.0.2",
    "expo-secure-store": "^57.0.0",
    "expo-status-bar": "~57.0.0",
    "phosphor-react-native": "^3.0.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-web": "^0.21.2",
    "react-native-webview": "^14.0.1"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "start:ios": "expo start --ios",
    "start:android": "EXPO_PUBLIC_API_URL=${EXPO_PUBLIC_API_URL:-http://10.0.2.2:5001/api} EXPO_PUBLIC_SOCKET_URL=${EXPO_PUBLIC_SOCKET_URL:-ws://10.0.2.2:5001/ws} expo start --go",
    "open:android": "bash scripts/open-android-expo.sh",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "check": "tsc --noEmit",
    "prebuild:android": "expo prebuild --platform android --clean",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:android:full": "npm run prebuild:android && npm run build:android",
    "build:ios": "xcodebuild -workspace ios/RemoteDate.xcworkspace -scheme RemoteDate -configuration Release -sdk iphonesimulator -derivedDataPath ios/build CODE_SIGNING_ALLOWED=NO",
    "build:ios:full": "npm run prebuild:ios && npm run build:ios"
  },
  "private": true
}
